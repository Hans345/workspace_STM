/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* MPU Configuration--------------------------------------------------------*/
  MPU_Config();

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  /* Configure the System Power */
  SystemPower_Config();

  /* Configure the system clock */
  SystemClock_Config();
  /* GTZC initialisation */
  MX_GTZC_Init();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_GPDMA1_Init();
  MX_ICACHE_Init();
  MX_FLASH_Init();
  MX_ADC1_Init();
  MX_ADC4_Init();
  MX_COMP1_Init();
  MX_COMP2_Init();
  MX_DAC1_Init();
  MX_FDCAN1_Init();
  MX_SPI1_Init();
  MX_TIM1_Init();
  MX_TIM8_Init();
  MX_USART3_UART_Init();
  MX_USART1_UART_Init();
  MX_TIM3_Init();
  /* USER CODE BEGIN 2 */

	// printf()
	printf("Start Monitoringsystem\r\n");

	// Start ADC Trigger
	HAL_TIM_Base_Start_IT(&htim3);

	// Start ADC mit DMA
	HAL_ADC_Start_DMA(&hadc1, (uint32_t*)&ADC_VAL[0], (int)(N/4));
	printf("ADC Sampling\r\n");

	// GPIO
	HAL_GPIO_WritePin(LD1_green_GPIO_Port, LD1_green_Pin, 0);

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  // FFT
	  // Sampling fertig -> FFT
	  if(qNr == 5)
	  {
		  printf("Do FFT\r\n");
		  calc_voltage(x, (int)N);
		  make_complex(x, c, (int)N);
		  fft(c, (int)N);
		  scale(c, (int)N);
		  abs_val(c, (int)N);
		  // FFT fertig
		  HAL_GPIO_WritePin(LD1_green_GPIO_Port, LD1_green_Pin, 1);
		  _write(0, "HELLO\n", 6);
		  HAL_GPIO_WritePin(LD1_green_GPIO_Port, LD1_green_Pin, 0);
		  qNr = 1;
	  }

	  // Delay
	  HAL_Delay(200);

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

