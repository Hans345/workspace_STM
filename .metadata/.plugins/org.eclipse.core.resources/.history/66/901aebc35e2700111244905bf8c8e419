// Diskrete Fourier Transformation (DFT)
// x: Zeitdiskretes Signal
// c: Komplexe Fourier Koeffizienzten ck
void dft(float x[], Complex c[])
{
	for(int k = 0; k < N; k++)
	{
		// Initalisierung
		c[k].real = 0;
		c[k].imag = 0;

		// Summe berechnen
		for(int n = 0; n < N; n++)
		{
			float phi = (-2.0*M_PI*k*n)/N;
			float cv = arm_cos_f32(phi);
			float sv = arm_sin_f32(phi);

			c[k].real = c[k].real + x[n]*cv;
			c[k].imag = c[k].imag + x[n]*sv;
		}

		// Skalierung
		c[k].real = (1.0/N)*c[k].real;
		c[k].imag = (1.0/N)*c[k].imag;

		// Betrag berechnen
		float result = 0;
		float temp = c[k].real*c[k].real + c[k].imag*c[k].imag;
		arm_sqrt_f32(temp, &result);
		c[k].abs = 2*result;	// Amplitude berechnen (An = 2*|cn|)
	}
}

// Komplexe Zahl aus Zeitsignal generieren
// x: Zeitdiskretes Signal
// c: Arbeitsarray
void make_complex(float x[], Complex c[])
{
	for(int i = 0; i < N; i++)
	{
	    c[i].real = x[i];
	    c[i].imag = 0.0;
	}
}

// Fast Fourier Transformation (FFT) simple (ohne rekursion)
// x: Zeitdiskretes Signal
// c: Komplexe Fourier Koeffizienzten ck
// n: Anzahl Samples
void fft_simple(const float x[], Complex c[], int n)
{
	// Aufteilen
	int ns = n/2;
	float xe[ns];
	float xo[ns];

	for(int i = 0; i < ns; i++)
	{
		xe[i] = x[2*i];
		xo[i] = x[2*i + 1];
	}

	// DFT für Teilprobleme lösen
    for(int k = 0; k < ns; k++)
    {
    	// Initialisierung
    	Complex cks;
    	cks.real = 0;
    	cks.imag = 0;
    	cks.abs = 0;
    	Complex ckss;
    	ckss.real = 0;
    	ckss.imag = 0;
    	ckss.abs = 0;
    	/*Complex ckzv;
    	ckzv.real = 0;
    	ckzv.imag = 0;
    	ckzv.abs = 0;*/

    	// Summen berechnen
    	for(int m = 0; m < ns; m++)
    	{
        	// Gerade Samples (ck')
			float phi = (-2.0*M_PI*k*m)/ns;
			float cv = arm_cos_f32(phi);
			float sv = arm_sin_f32(phi);
			cks.real = cks.real + xe[m]*cv;
			cks.imag = cks.imag + xe[m]*sv;

        	// Ungerade Samples (ck'')
			phi = (-2.0*M_PI*k*m)/ns;
			cv = arm_cos_f32(phi);
			sv = arm_sin_f32(phi);
			ckss.real = ckss.real + xo[m]*cv;
			ckss.imag = ckss.imag + xo[m]*sv; // Vorzeichen in Matlab invers!
    	}
    	// Zeitverschiebung
		/*float phi = (-2.0*M_PI*k)/N;
		float cv = arm_cos_f32(phi);
		float sv = arm_sin_f32(phi);
		ckzv.real = ckss.real*cv;
		ckzv.imag = ckss.imag*sv;*/

		// ck berechnen
		c[k].real = 1.0/(2*ns)*(cks.real + ckss.real);
		c[k].imag = 1.0/(2*ns)*(cks.imag + ckss.imag);

		// Betrag berechnen
		float result = 0;
		float temp = c[k].real*c[k].real + c[k].imag*c[k].imag;
		arm_sqrt_f32(temp, &result);
		c[k].abs = 2*result;	// Amplitude berechnen (An = 2*|cn|)
    }

}

