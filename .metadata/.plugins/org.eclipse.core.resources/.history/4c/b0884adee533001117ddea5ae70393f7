#ifndef FUNKTIONEN_FFT_H_
#define FUNKTIONEN_FFT_H_

// Diskrete Fourier Transformation (DFT)
// x: Zeitdiskretes Signal
// c: Komplexe Fourier Koeffizienzten ck
// Rechenaufwand: O(N^2)
void dft(float x[], Complex c[], int N)
{
	for(int k = 0; k < N; k++)
	{
		// Initalisierung
		c[k].real = 0;
		c[k].imag = 0;

		// Summe berechnen
		for(int n = 0; n < N; n++)
		{
			float phi = (-2.0*M_PI*k*n)/N;
			float cv = arm_cos_f32(phi);
			float sv = arm_sin_f32(phi);

			c[k].real = c[k].real + x[n]*cv;
			c[k].imag = c[k].imag + x[n]*sv;
		}
	}
}

// Fast Fourier Transfromation (FFT)
// c: Komplexe Fourier Koeffizienzten ck
// N: Anzahl Samples
// Rechenaufwand: O(N*log(N))
void fft(Complex c[], int N)
{
	if (N <= 1) return;

	// Aufteilen
	Complex ce[N/2];
	Complex co[N/2];
	for (int i = 0; i < N/2; i++)
	{
		ce[i] = c[2*i];
		co[i] = c[2*i + 1];
	}

    // Rekursion
	fft(ce, N/2);
	fft(co, N/2);

    // Kombinieren
    for (int k = 0; k < N/2; k++) {
        float angle = (-2.0*M_PI*k)/N;
        Complex twiddle = complex_exp(angle);

        Complex t = complex_mul(twiddle, co[k]);

        c[k]       = complex_add(ce[k], t);
        c[k+N/2]   = complex_sub(ce[k], t);
    }
}

/**
 * @brief Rechnet ADC Werte in Spannungen um. Greift auf globale Arrays für ADC Werte und Spannungswerte zu.
 *
 * @param nS Buffer Länge
 * @note Die Bufferlänge für die ADC-Werte (ADC_VAL) und die Spannungswerte (x) muss gleich sein!
 */
void calc_voltage(const uint16_t ADC_VAL[], float x[], int nS) {
	for (int i = 0; i < nS; i++) {
		float voltage = (ADC_VAL[i] / 16383.0) * 3.3;
		x[i] = voltage;
	}
}


#endif /* FUNKTIONEN_FFT_H_ */
